# Whisper integration — environment variables template
# Copy to .env and adjust as needed.
# This file is safe to commit; .env is not.

# Whisper model to use: tiny, base, small, medium, large-v3
# Default: small (best balance on Raspberry Pi 5 / ARM64 CPU)
WHISPER_MODEL=small

# Inference device: cpu or cuda
# Raspberry Pi 5 has no GPU — always use cpu
WHISPER_DEVICE=cpu

# Primary transcription language (ISO 639-1 code)
# nl = Dutch, en = English
# Set to empty string to let Whisper auto-detect
WHISPER_LANGUAGE=nl
