# Larry Bridge — bearer token for n8n → Larry authentication
# Bitwarden item: "Larry Bridge / Token"
LARRY_TOKEN=

# Timeout per Claude invocation in seconds (default: 180)
# Bitwarden item: n/a — set to 180 unless adjusted
LARRY_TIMEOUT=

# Listening port (default: 8765)
# Bitwarden item: n/a — set to 8765 unless adjusted
LARRY_PORT=

# n8n API key for flow management from Larry
# Bitwarden item: "n8n / API Key"
N8N_API_KEY=

# n8n base URL
# Bitwarden item: "n8n / Network"
N8N_BASE_URL=
